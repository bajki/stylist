{
    "name": "bajki/stylist",
    "description": "Laravel 7 theming package.",
    "authors": [
        {
            "name": "Kirk Bushell",
            "email": "torm3nt@gmail.com"
        },
        {
            "name": "Mike Dugan",
            "email": "mike@mjdugan.com"
        },
        {
            "name": "Yassine Kraiem",
            "email": "kamisama953@gmail.com"
        }
    ],
    "require": {
        "php": "^7.4",
        "laravel/framework": "~5.2.0||~5.3.0||~5.4.0||~5.5.0||~5.6.0||~5.7.0||~5.8.0||^6.0||^7.0|^8"
    },
    "require-dev": {
        "mockery/mockery": "^1.0",
        "orchestra/testbench": "^4.0",
        "phpunit/phpunit": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "FloatingPoint\\Stylist\\": "src/Stylist"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FloatingPoint\\Stylist\\StylistServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "config": {
        "preferred-install": "dist"
    },
    "license": "MIT",
    "version": "1.0"
}
